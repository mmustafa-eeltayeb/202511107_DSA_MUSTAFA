#include <iostream>
#include <string>
using namespace std;

struct Task {
    int taskId;
    string taskName;
    int priority;
};

int main() {
    Task scheduler[3];

    // Input loop for tasks
    for (int i = 0; i < 3; i++) {
        cout << "Enter Task ID: ";
        cin >> scheduler[i].taskId;
        cout << "Enter Task Name: ";
        cin.ignore();
        getline(cin, scheduler[i].taskName);
        cout << "Enter Priority (1-5): ";
        cin >> scheduler[i].priority;
    }

    // Output loop for displaying schedule
    cout << "\n--- Scheduled Tasks ---" << endl;
    for (int i = 0; i < 3; i++) {
        cout << "ID: " << scheduler[i].taskId 
             << " | Name: " << scheduler[i].taskName 
             << " | Priority: " << scheduler[i].priority << endl;
    }

    return 0;
}
